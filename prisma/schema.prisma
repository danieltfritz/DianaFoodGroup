generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  password      String
  role          String          @default("staff")
  createdAt     DateTime        @default(now())
  kidCountAudit KidCountAudit[]
}

// ─── Reference / Lookup ──────────────────────────────────────────────────────

model AgeGroup {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(50)
  startAge     Int
  endAge       Int
  kidCounts    KidCount[]
  mealPrices   MealPrice[]
  servingSizes ServingSize[]
}

model Meal {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(50)
  kidCounts    KidCount[]
  mealPrices   MealPrice[]
  menuItems    MenuItem[]
  servingSizes ServingSize[]
}

model Route {
  id      Int      @id @default(autoincrement())
  name    String   @db.VarChar(50)
  driver  String?  @db.VarChar(50)
  schools School[]
}

model County {
  id      Int      @id @default(autoincrement())
  name    String   @db.VarChar(50)
  schools School[]
}

model MenuType {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(50)
}

model FoodType {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(50)
}

// ─── Schools ─────────────────────────────────────────────────────────────────

model School {
  id             Int                  @id @default(autoincrement())
  name           String               @db.VarChar(100)
  address        String?
  city           String?
  state          String?              @db.VarChar(20)
  postalCode     String?              @db.VarChar(20)
  contactName    String?              @db.VarChar(100)
  phone          String?              @db.VarChar(30)
  email          String?              @db.VarChar(100)
  fax            String?              @db.VarChar(30)
  routeId        Int?
  countyId       Int?
  deliveryMon    Boolean              @default(false)
  deliveryTue    Boolean              @default(false)
  deliveryWed    Boolean              @default(false)
  deliveryThu    Boolean              @default(false)
  deliveryFri    Boolean              @default(false)
  deliverySat    Boolean              @default(false)
  deliverySun    Boolean              @default(false)
  notes          String?
  active         Boolean              @default(true)
  milkTier       String               @default("medium") @db.VarChar(10)
  route          Route?               @relation(fields: [routeId], references: [id])
  county         County?              @relation(fields: [countyId], references: [id])
  schoolMenus    SchoolMenu[]
  kidCounts      KidCount[]
  mealPrices     MealPrice[]
  schoolClosings SchoolClosing[]
  billingGroups  BillingSchoolGroup[]
  milkCounts     MilkCount[]
  paperGroups    SchoolPaperGroup[]
  paperComment   SchoolPaperComment?
  paperOverrides PaperOverride[]
  paperRunAmounts PaperRunSchoolAmount[]
}

// ─── Food Catalog ─────────────────────────────────────────────────────────────

model Container {
  id           Int             @id @default(autoincrement())
  name         String          @db.VarChar(50)
  isVariable   Boolean         @default(false)
  allowPartial Boolean         @default(false)
  menuTypeId   Int?
  units        String?         @db.VarChar(50)
  sizes        ContainerSize[]
  foodItems    FoodItem[]
}

model ContainerSize {
  id           Int       @id @default(autoincrement())
  containerId  Int
  name         String    @db.VarChar(50)
  abbreviation String    @db.VarChar(50)
  size         Decimal   @db.Decimal(10, 4)
  container    Container @relation(fields: [containerId], references: [id])
}

model FoodItem {
  id                 Int            @id @default(autoincrement())
  name               String         @db.VarChar(100)
  tempType           String         @db.VarChar(10)
  foodTypeId         Int?
  isMilk             Boolean        @default(false)
  hasLabel           Boolean        @default(true)
  showOnReport       Boolean        @default(true)
  menuTypeId         Int?
  defaultContainerId Int?
  containerThreshold Decimal?       @db.Decimal(10, 4)
  containerStrategy  String         @default("LeastContainers") @db.VarChar(20)
  pkSize             Int?
  pkUnit             String?        @db.VarChar(50)
  container          Container?     @relation(fields: [defaultContainerId], references: [id])
  servingSizes       ServingSize[]
  menuItems          MenuItem[]
  milkOverrides      MilkOverride[]
}

model ServingSize {
  id          Int      @id @default(autoincrement())
  mealId      Int
  foodItemId  Int
  ageGroupId  Int
  servingSize Decimal  @db.Decimal(10, 4)
  meal        Meal     @relation(fields: [mealId], references: [id])
  foodItem    FoodItem @relation(fields: [foodItemId], references: [id])
  ageGroup    AgeGroup @relation(fields: [ageGroupId], references: [id])

  @@unique([mealId, foodItemId, ageGroupId])
}

// ─── Menus ────────────────────────────────────────────────────────────────────

model Menu {
  id            Int          @id @default(autoincrement())
  name          String       @db.VarChar(50)
  cycleWeeks    Int
  effectiveDate DateTime     @db.Date
  isBoxMenu     Boolean      @default(false)
  delaySnack    Boolean      @default(false)
  menuTypeId    Int?
  items         MenuItem[]
  schoolMenus   SchoolMenu[]
  paperItems    MenuPaperItem[]
}

model MenuItem {
  id         Int      @id @default(autoincrement())
  menuId     Int
  foodItemId Int
  mealId     Int
  week       Int
  dayId      Int
  menu       Menu     @relation(fields: [menuId], references: [id])
  foodItem   FoodItem @relation(fields: [foodItemId], references: [id])
  meal       Meal     @relation(fields: [mealId], references: [id])

  @@unique([menuId, foodItemId, mealId, week, dayId])
}

model SchoolMenu {
  id            Int            @id @default(autoincrement())
  schoolId      Int
  menuId        Int
  startDate     DateTime       @db.Date
  endDate       DateTime?      @db.Date
  school        School         @relation(fields: [schoolId], references: [id])
  menu          Menu           @relation(fields: [menuId], references: [id])
  kidCounts     KidCount[]
  mealPrices    MealPrice[]
  milkOverrides MilkOverride[]
}

model SchoolClosing {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  school    School   @relation(fields: [schoolId], references: [id])
}

// ─── Core Fact Table ──────────────────────────────────────────────────────────

model KidCount {
  id           Int         @id @default(autoincrement())
  schoolId     Int
  schoolMenuId Int
  date         DateTime    @db.Date
  mealId       Int
  ageGroupId   Int
  count        Int
  updatedAt    DateTime    @updatedAt
  school       School      @relation(fields: [schoolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  schoolMenu   SchoolMenu  @relation(fields: [schoolMenuId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  meal         Meal        @relation(fields: [mealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ageGroup     AgeGroup    @relation(fields: [ageGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([schoolId, date, mealId, ageGroupId])
  @@index([date])
  @@index([schoolId, date])
}

model MilkType {
  id         Int         @id
  name       String      @db.VarChar(50)
  labelColor String      @db.VarChar(50)
  milkCounts MilkCount[]
}

model MilkCount {
  id         Int      @id @default(autoincrement())
  schoolId   Int
  date       DateTime @db.Date
  mealId     Int
  milkTypeId Int
  count      Int      @default(0)
  school     School   @relation(fields: [schoolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  milkType   MilkType @relation(fields: [milkTypeId], references: [id])

  @@unique([schoolId, date, mealId, milkTypeId])
  @@index([schoolId, date])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model BillingGroup {
  id      Int                  @id @default(autoincrement())
  name    String               @db.VarChar(50)
  schools BillingSchoolGroup[]
}

model BillingSchoolGroup {
  id             Int          @id @default(autoincrement())
  billingGroupId Int
  schoolId       Int
  billingGroup   BillingGroup @relation(fields: [billingGroupId], references: [id])
  school         School       @relation(fields: [schoolId], references: [id])

  @@unique([billingGroupId, schoolId])
}

model MealPrice {
  id           Int        @id @default(autoincrement())
  schoolMenuId Int
  schoolId     Int
  mealId       Int
  ageGroupId   Int
  price        Decimal    @db.Decimal(10, 4)
  schoolMenu   SchoolMenu @relation(fields: [schoolMenuId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  school       School     @relation(fields: [schoolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  meal         Meal       @relation(fields: [mealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ageGroup     AgeGroup   @relation(fields: [ageGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([schoolMenuId, schoolId, mealId, ageGroupId])
}

model QbMealCode {
  id              Int    @id @default(autoincrement())
  transactionType String @db.VarChar(50)
  qbCode          String @db.VarChar(50)
  order           Int
  mealId          Int
  ageGroupId      Int
  description     String @db.VarChar(100)
}

model BillingRun {
  id           Int                @id @default(autoincrement())
  deliveryDate DateTime           @db.Date
  createdAt    DateTime           @default(now())
  details      BillingRunDetail[]
}

model BillingRunDetail {
  id           Int        @id @default(autoincrement())
  billingRunId Int
  schoolId     Int
  mealId       Int
  ageGroupId   Int
  isBox        Boolean    @default(false)
  kidCount     Int
  priceUsed    Decimal    @db.Decimal(10, 4)
  billingRun   BillingRun @relation(fields: [billingRunId], references: [id])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model KidCountAudit {
  id         Int      @id @default(autoincrement())
  schoolId   Int
  date       DateTime @db.Date
  mealId     Int
  ageGroupId Int
  oldCount   Int
  newCount   Int
  userId     String
  changedAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([schoolId, date])
}

// ─── Paper Goods ─────────────────────────────────────────────────────────────

model PaperGroup {
  id      Int                  @id
  name    String               @db.VarChar(100)
  schools SchoolPaperGroup[]
  runs    PaperProductionRun[]
}

model SchoolPaperGroup {
  id           Int        @id @default(autoincrement())
  schoolId     Int
  paperGroupId Int
  school       School     @relation(fields: [schoolId], references: [id])
  paperGroup   PaperGroup @relation(fields: [paperGroupId], references: [id])

  @@unique([schoolId, paperGroupId])
}

model SchoolPaperComment {
  id       Int    @id @default(autoincrement())
  schoolId Int    @unique
  comment  String @db.VarChar(1000)
  school   School @relation(fields: [schoolId], references: [id])
}

model PaperProductionRun {
  id           Int                    @id @default(autoincrement())
  startDate    DateTime               @db.Date
  endDate      DateTime               @db.Date
  createdAt    DateTime               @default(now())
  paperGroupId Int?
  notes        String?                @db.VarChar(500)
  group        PaperGroup?            @relation(fields: [paperGroupId], references: [id])
  amounts      PaperRunSchoolAmount[]
}

model PaperRunSchoolAmount {
  id          Int                @id @default(autoincrement())
  runId       Int
  schoolId    Int
  paperId     Int
  paperSizeId Int?
  totalQty    Int
  run         PaperProductionRun @relation(fields: [runId], references: [id])
  school      School             @relation(fields: [schoolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paper       PaperItem          @relation("RunAmountPaper", fields: [paperId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paperSize   PaperSize?         @relation("RunAmountSize", fields: [paperSizeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([runId, schoolId])
}

model FoodPaperItem {
  id          Int        @id
  schoolId    Int?
  foodId      Int
  mealId      Int
  ageGroupId  Int
  paperId     Int
  paperSizeId Int?
  isAlways    Boolean    @default(false)
  paper       PaperItem  @relation("FoodPaperItemPaper", fields: [paperId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paperSize   PaperSize? @relation("FoodPaperItemSize", fields: [paperSizeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([foodId, mealId, ageGroupId])
}

model PaperOverride {
  id            Int        @id
  schoolId      Int
  mealId        Int
  ageGroupId    Int
  paperId       Int
  paperSizeId   Int?
  orPaperId     Int?
  orPaperSizeId Int?
  school        School     @relation(fields: [schoolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paper         PaperItem  @relation("OverridePaper", fields: [paperId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orPaper       PaperItem? @relation("OverrideOrPaper", fields: [orPaperId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paperSize     PaperSize? @relation("OverridePaperSize", fields: [paperSizeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orPaperSize   PaperSize? @relation("OverrideOrPaperSize", fields: [orPaperSizeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([schoolId, mealId, ageGroupId])
}

model MenuPaperItem {
  id          Int        @id
  schoolId    Int?
  menuId      Int
  week        Int
  dayId       Int
  mealId      Int
  ageGroupId  Int
  paperId     Int
  paperSizeId Int?
  paperQty    Int        @default(0)
  isAlways    Boolean    @default(false)
  menu        Menu       @relation(fields: [menuId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paper       PaperItem  @relation(fields: [paperId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paperSize   PaperSize? @relation(fields: [paperSizeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([menuId, week, dayId])
}

model PaperItem {
  id              Int              @id
  name            String           @db.VarChar(100)
  active          Boolean          @default(true)
  sizes           PaperSize[]
  containers      PaperContainer[]
  menuItems       MenuPaperItem[]
  foodPaperItems  FoodPaperItem[]  @relation("FoodPaperItemPaper")
  overrides       PaperOverride[]  @relation("OverridePaper")
  orOverrides     PaperOverride[]  @relation("OverrideOrPaper")
  runAmounts      PaperRunSchoolAmount[] @relation("RunAmountPaper")
}

model PaperSize {
  id              Int              @id
  paperId         Int
  name            String?          @db.VarChar(50)
  paper           PaperItem        @relation(fields: [paperId], references: [id])
  containers      PaperContainer[]
  menuItems       MenuPaperItem[]
  foodPaperItems  FoodPaperItem[]  @relation("FoodPaperItemSize")
  overrides       PaperOverride[]  @relation("OverridePaperSize")
  orOverrides     PaperOverride[]  @relation("OverrideOrPaperSize")
  runAmounts      PaperRunSchoolAmount[] @relation("RunAmountSize")
}

model PaperContainer {
  id            Int       @id
  paperId       Int
  paperSizeId   Int
  containerName String    @db.VarChar(50)
  containerSize Int
  paper         PaperItem @relation(fields: [paperId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paperSize     PaperSize @relation(fields: [paperSizeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Milk Overrides ───────────────────────────────────────────────────────────

model MilkOverride {
  id              Int        @id @default(autoincrement())
  schoolMenuId    Int
  foodItemId      Int
  milkFoodItemId  Int
  containerSizeId Int
  containerCount  Int
  schoolMenu      SchoolMenu @relation(fields: [schoolMenuId], references: [id])
  foodItem        FoodItem   @relation(fields: [foodItemId], references: [id])
}
